{
  "expo": {
    "name": "LocalServicesProvider",
    "slug": "local-services-provider",
    "version": "0.0.1",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "newArchEnabled": true,
    "scheme": "localservices",
    "experiments": {
      "typedRoutes": true
    },
    "plugins": [
      "expo-secure-store",
      "expo-router"
    ],
    "ios": {
      "bundleIdentifier": "com.anonymous.local-services-provider"
    }
  }
}
