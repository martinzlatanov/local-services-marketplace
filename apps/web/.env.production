# Production Environment Variables for Vercel
# Copy these to Vercel Project Settings → Environment Variables

# Neon Production Database Connection String
DATABASE_URL=postgres://user:password@ep-xxx.us-east-1.aws.neon.tech/local_services_prod?sslmode=require

# JWT Secret for authentication tokens
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# WebSocket URL (if using separate WebSocket server)
# NEXT_PUBLIC_WS_URL=wss://your-app.vercel.app
